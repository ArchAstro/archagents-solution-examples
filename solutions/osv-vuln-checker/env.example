# Environment variables for the OSV Vulnerability Checker.
#
# Mirror every env var declared in a template's `setup_actions:` here so
# local development and reviewers have a template to copy from. Real values
# are set per-agent after install (in the agent's settings, or via the CLI
# env management) — never commit real secrets to this repo.

# Comma-separated `ecosystem:name@version` entries the weekly scan walks.
# Required by the weekly-scan routine.
MONITORED_PACKAGES=npm:lodash@4.17.20,PyPI:requests@2.25.0

# Optional Slack channel for the weekly triage summary. Leave blank to keep
# results in-thread only.
NOTIFY_CHANNEL=
